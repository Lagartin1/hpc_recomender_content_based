FROM python:3.12-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY src ./src

CMD ["python", "src/benchmark_amazon/run_amazon_local.py", "--backends", "numpy,ray_cpu", "--csv", "/app/results/amazon_local_cpu_benchmark.csv", "--output-dir", "/app/results"]
